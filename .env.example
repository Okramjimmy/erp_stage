# Application
APP_NAME=ERP Stage Builder
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production-please

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/erp_stage
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=erp_stage
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Cache TTL (in seconds)
CACHE_TTL_MASTER_METADATA=3600
CACHE_TTL_STAGE_PATH=86400
CACHE_TTL_VISIBLE_STAGES=900
CACHE_TTL_PERMISSIONS=1800

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=100
